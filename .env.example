# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role: necesaria para que el servidor escriba credenciales
# y la identidad del issuer saltándose RLS. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Strava
# ─────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Resend
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────
# ACTA — red
# ─────────────────────────────────────────────────────────────
# "testnet" | "mainnet". Define contra qué host se habla:
#   testnet -> https://api.testnet.acta.build
#   mainnet -> https://api.mainnet.acta.build
ACTA_NETWORK=testnet

# ─────────────────────────────────────────────────────────────
# ACTA — API keys (X-ACTA-Key, 64 chars hex, 1 por wallet por red)
# ─────────────────────────────────────────────────────────────
# Key estándar. El SDK resuelve por red: primero la específica,
# luego ACTA_API_KEY como fallback. Creala en https://dapp.acta.build
ACTA_API_KEY_TESTNET=
ACTA_API_KEY_MAINNET=
# ACTA_API_KEY=

# Key ADMIN (rol admin). Exenta del ownership binding, así que habilita:
#   - emitir en vaults que no son de nuestra wallet
#   - POST /contracts/sponsored-vault/create (vault pagado por sponsor)
#   - leer get-vc / list-vc-ids de cualquier owner
# Solo se usa en el servidor y solo en los flujos que la exigen.
# Si queda vacía, la app funciona igual en modo org-vault (ver ACTA_VAULT_MODE).
ACTA_ADMIN_KEY_TESTNET=
ACTA_ADMIN_KEY_MAINNET=
# ACTA_ADMIN_KEY=

# ─────────────────────────────────────────────────────────────
# ACTA — wallet emisora
# ─────────────────────────────────────────────────────────────
# Secret key (S...) de la cuenta Stellar de la organización.
# Firma cada emisión Y paga la tarifa on-chain:
#   testnet 5 XLM por credencial · mainnet 1 USDC por credencial
# En mainnet la cuenta necesita trustline de USDC con saldo.
# Debe ser la wallet ligada a ACTA_API_KEY_* (si no, 403 ownership violation).
ACTA_ISSUER_SECRET=
# Public key (G...) derivada del secret. Opcional: si se define, se valida
# que coincida con el secret al arrancar — atrapa mezclar claves de redes.
ACTA_ISSUER_PUBLIC=

# ─────────────────────────────────────────────────────────────
# ACTA — modo de vault
# ─────────────────────────────────────────────────────────────
# "org"       -> un único vault de la organización guarda todas las
#                constancias. Funciona con key estándar. Default.
# "sponsored" -> cada corredor tiene su vault, pagado por la organización
#                vía sponsored-vault/create. EXIGE ACTA_ADMIN_KEY_* y que
#                el corredor tenga una dirección Stellar registrada.
ACTA_VAULT_MODE=org

# ─────────────────────────────────────────────────────────────
# ACTA — identidad del issuer (did:stellar)
# ─────────────────────────────────────────────────────────────
# Clave de 32 bytes en hex (64 chars) para cifrar AES-256-GCM la llave
# privada de aserción del DID antes de guardarla en Supabase.
# Generala con:  openssl rand -hex 32
ACTA_IDENTITY_ENCRYPTION_KEY=

# Opcional: si ya registraste el did:stellar de la organización, pegalo acá
# para saltarte el auto-onboarding. Formato did:stellar:{network}:{26 chars}
# ACTA_ISSUER_DID=

# ─────────────────────────────────────────────────────────────
# ACTA — identidad del corredor (did:web)
# ─────────────────────────────────────────────────────────────
# Host que sirve los documentos DID de los corredores. Debe ser el dominio
# público de este deploy: el DID did:web:{host}:corredor:{id} se resuelve en
# https://{host}/corredor/{id}/did.json, que esta misma app publica.
NEXT_PUBLIC_SITE_HOST=informatico.run

# ─────────────────────────────────────────────────────────────
# ACTA — emisión
# ─────────────────────────────────────────────────────────────
# Si es "false", la app registra lo que emitiría pero no toca la cadena
# ni gasta tarifa. Útil para probar el flujo de admin sin quemar XLM/USDC.
ACTA_ISSUANCE_ENABLED=true
